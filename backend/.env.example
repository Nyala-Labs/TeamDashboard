# Database - DATABASE_URL from Supabase (use pooler port 6543 for serverless)
# Local: postgresql://postgres:postgres@localhost:5432/nyala_dashboard
# Supabase: postgres://postgres.[REF]:[PWD]@xxx.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nyala_dashboard

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Calendar (place credentials.json from Google Cloud Console)
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=token.json

# CORS (for local dev)
CORS_ORIGINS=["http://localhost:3000"]
