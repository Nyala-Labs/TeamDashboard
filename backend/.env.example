# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nyala_dashboard
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/nyala_dashboard

# Auth (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Calendar (place credentials.json from Google Cloud Console)
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=token.json

# CORS
CORS_ORIGINS=["http://localhost:3000"]
