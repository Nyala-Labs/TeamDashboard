# =============================================================================
# Nyala Labs Dashboard - Environment Variables
# =============================================================================
# Copy to .env (root) and frontend/.env.local. Add backend/.env for local API.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase)
# -----------------------------------------------------------------------------
# From Supabase: Project Settings > Database > Connection string
# Use Transaction pooler (port 6543) for serverless; Direct (5432) for migrations.
# Example: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
DATABASE_URL=

# -----------------------------------------------------------------------------
# Vercel / Frontend
# -----------------------------------------------------------------------------
# Leave empty or set to /api for production (same-origin rewrites to Python backend).
# For local dev, set to http://localhost:8000 when running backend separately.
NEXT_PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Backend (optional, for local uvicorn)
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
